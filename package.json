    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.30",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
