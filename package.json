{
  "name": "menu-parser-node",
  "version": "1.1.0",
  "description": "PDF menu parser API for TableSomm",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "parse": "tsx src/index.ts"
